# Shared
NODE_ENV=development

# API
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_ADMIN_URL=http://localhost:5173
DESKTOP_APP_URL=http://localhost:5174
JWT_ACCESS_SECRET=replace-with-64-byte-random-secret
JWT_REFRESH_SECRET=replace-with-another-64-byte-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# PostgreSQL
DATABASE_URL=postgresql://id_daddy:id_daddy@127.0.0.1:55432/id_daddy?schema=public

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# S3 compatible storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=id-daddy
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_FORCE_PATH_STYLE=true
SIGNED_URL_TTL_SECONDS=900



# Stripe (Optional - Currently disabled)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Initial seed super admin
SEED_SUPER_ADMIN_EMAIL=admin@retaildaddy.in
SEED_SUPER_ADMIN_PASSWORD=retaildaddy@0123

# Email Verification (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=ID Daddy <your_email@gmail.com>
