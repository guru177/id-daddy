generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  STAFF
  VIEWER

  @@map("role")
}

enum Plan {
  FREE
  BASIC
  PRO

  @@map("plan")
}

enum WorkspaceStatus {
  ACTIVE
  BLOCKED
  PAST_DUE
  CANCELED

  @@map("workspace_status")
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED

  @@map("export_status")
}

model Workspace {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  plan         Plan            @default(FREE)
  status       WorkspaceStatus @default(ACTIVE)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  users        User[]
  templates    Template[]
  records      Record[]
  exports      Export[]
  subscription Subscription?
  usageLogs    UsageLog[]

  @@index([status])
  @@map("workspaces")
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String?    @map("workspace_id") @db.Uuid
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         Role
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([role])
  @@map("users")
}

model Template {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String
  design      Json      @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("templates")
}

model Record {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  data        Json      @db.JsonB
  imageUrl    String?   @map("image_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("records")
}

model Export {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  fileUrl     String?      @map("file_url")
  status      ExportStatus @default(PENDING)
  error       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
  @@map("exports")
}

model Subscription {
  workspaceId String    @id @map("workspace_id") @db.Uuid
  plan        Plan
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UsageLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  action      String
  count       Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, action, createdAt])
  @@map("usage_logs")
}
