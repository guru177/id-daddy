{
  "name": "id-daddy-saas",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-tenant ID card generator SaaS with NestJS, PostgreSQL RLS, React, and Electron.",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @id-daddy/api --filter @id-daddy/web-admin --filter @id-daddy/desktop dev",
    "dev:api": "pnpm --filter @id-daddy/api dev",
    "dev:web": "pnpm --filter @id-daddy/web-admin dev",
    "dev:desktop": "pnpm --filter @id-daddy/desktop dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @id-daddy/api prisma:migrate",
    "db:seed": "pnpm --filter @id-daddy/api prisma:seed",
    "docker:up": "docker compose up -d postgres redis minio",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "bwip-js": "^4.10.1"
  }
}
